# Chatwoot Configuration
# These are required for the integration to work

# The base URL of your Chatwoot instance (e.g., https://app.chatwoot.com or your self-hosted URL)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# API access token from Chatwoot (found in Profile Settings > Access Token)
CHATWOOT_API_TOKEN=your_api_token_here

# The inbox ID for the API channel (found in Settings > Inboxes > Your Inbox)
CHATWOOT_INBOX_ID=1

# Your Chatwoot account ID (found in the URL when logged in)
CHATWOOT_ACCOUNT_ID=1

# Optional: Webhook secret for signature verification
# Set this in your Chatwoot webhook configuration to secure the endpoint
CHATWOOT_WEBHOOK_SECRET=your_webhook_secret_here

# Session secret for Express sessions
SESSION_SECRET=your_session_secret_here
