# Port the server listens on
PORT=5001

# Secret used to sign session cookies — use any long random string
# Generate one with: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_secret

# ── Database ────────────────────────────────────────────────────────────────
# Supports MySQL or PostgreSQL. Pick one and remove the other.

# MySQL (default)
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://whatsapp:whatsapp123@127.0.0.1:3306/chatwoot_bridge

# PostgreSQL (alternative)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://whatsapp:whatsapp123@127.0.0.1:5432/chatwoot_bridge
